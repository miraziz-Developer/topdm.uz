APP_NAME=Bozor-AI Engine
APP_ENV=dev
APP_DEBUG=true
API_PREFIX=/api/v1

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=bozor_ai
POSTGRES_USER=bozor
POSTGRES_PASSWORD=bozor
DATABASE_URL=postgresql://bozor:bozor@localhost:5432/bozor_ai
REDIS_URL=redis://localhost:6379/0

# Email OTP (Resend) — https://resend.com
RESEND_API_KEY=re_xxxx
RESEND_FROM_EMAIL=Bozor AI <onboarding@resend.dev>

# Telegram OTP (bepul) — foydalanuvchi avval botda /start bosishi kerak
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_BOT_USERNAME=your_bot_username
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=your_bot_username

JWT_SECRET=change-me-in-production
# Same-origin proxy (recommended — HttpOnly cookie session)
NEXT_PUBLIC_API_BASE_URL=/api/v1
BACKEND_API_URL=http://127.0.0.1:8000
# WebSocket still connects to FastAPI directly
NEXT_PUBLIC_BACKEND_ORIGIN=http://localhost:8000
NEXT_PUBLIC_SITE_URL=http://localhost:3002

# REQUIRED — Bozor AI stylist (official groq SDK in app/services/groq_stylist.py). Do not commit secrets.
GROQ_API_KEY=your-groq-key
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_AGENT_MODEL=
GROQ_VISION_MODEL=llama-3.2-11b-vision-preview
GEMINI_MODEL=gemini-2.0-flash
GOOGLE_API_KEY=your-google-api-key
# Xarita: yandex-maps-api (tavsiya — Yandex Navigator kabi haqiqiy piyoda yo‘l)
NEXT_PUBLIC_MAP_PROVIDER=yandex-maps-api
# Yandex: https://developer.tech.yandex.ru/ → «JavaScript API va HTTP Geocoder» + «Маршрутизация»
# Kalit sozlamalarida «HTTP referrer»: http://localhost:3002/* , http://127.0.0.1:3002/* , https://topdim.uz/*
NEXT_PUBLIC_YANDEX_MAPS_API_KEY=your-yandex-maps-key
# Server marshrut (MapLibre zaxirasida ham shu yo‘l chiziladi); bo‘sh qoldirilsa yuqoridagi kalit ishlatiladi
YANDEX_ROUTER_API_KEY=
# MapLibre zaxira (Yandex kalit bo'lmasa)
NEXT_PUBLIC_MAPTILER_KEY=your-maptiler-key
OPENROUTESERVICE_API_KEY=
GRAPHHOPPER_API_KEY=

FRONTEND_PORT=3002
MERCHANT_CRM_PORT=3003
MERCHANT_CRM_WEBAPP_URL=http://localhost:3003
NEXT_PUBLIC_MERCHANT_CRM_URL=http://localhost:3003

MEDIA_STORAGE_BACKEND=local
# Production: s3 — docs/MEDIA_S3_CDN.md
# S3_ENDPOINT_URL=
# S3_BUCKET=topdim-media
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_PUBLIC_BASE_URL=https://media.topdim.uz
# NEXT_PUBLIC_MEDIA_CDN_URL=https://media.topdim.uz
# Dev MinIO: docker compose --profile s3dev up -d minio minio-init
# MEDIA_STORAGE_BACKEND=s3
# S3_ENDPOINT_URL=http://minio:9000
# S3_PUBLIC_BASE_URL=http://localhost:9000/topdim-media
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Onlayn to'lov (Click / Payme) — dev da yoqish mumkin; production da haqiqiy kalitlar kerak
ENABLE_ONLINE_CHECKOUT=true
NEXT_PUBLIC_ENABLE_ONLINE_CHECKOUT=true
PAYMENT_CHECKOUT_BASE_URL=http://localhost:3002
CLICK_SERVICE_ID=
CLICK_SECRET_KEY=
CLICK_MERCHANT_ID=
PAYME_MERCHANT_ID=
PAYME_SECRET_KEY=
# Production callback IP (Click/Payme): vergul bilan
# PAYMENT_CALLBACK_IP_WHITELIST=185.139.0.0/24
PAYMENT_CALLBACK_MAX_AGE_SECONDS=900

# Yandex Delivery B2B (logistics)
YANDEX_DELIVERY_TOKEN="y0__wgBELu44fEHGIPLQiCGtuvXF9hc16CqFOeDSOg5MVutYM0eknRm"
YANDEX_API_URL="https://b2b.taxi.yandex.net"
IS_DELIVERY_SANDBOX=True
YANDEX_DELIVERY_RUB_TO_UZS=150
