# Replace domains with your production hostnames (DNS A/AAAA → server IP).
# TLS certificates are issued automatically by Caddy (Let's Encrypt).

{$SITE_DOMAIN:topdim.uz} {
	encode gzip zstd
	reverse_proxy frontend:3000
}

{$API_DOMAIN:api.topdim.uz} {
	encode gzip zstd
	reverse_proxy backend:8000
}

{$CRM_DOMAIN:crm.topdim.uz} {
	encode gzip zstd
	reverse_proxy merchant-crm:3000
}
