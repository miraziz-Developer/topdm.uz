# Browser: same-origin proxy (prod). Dev: direct backend OK too.
NEXT_PUBLIC_API_BASE_URL=/api/v1
# Server-side proxy target (Docker: http://backend:8000)
BACKEND_API_URL=http://127.0.0.1:8000
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=your_bot_username
# Dev (Docker): browser WS → host backend (Next dev does not proxy /ws/)
# NEXT_PUBLIC_BACKEND_ORIGIN=http://localhost:8000
# Optional override when WS is on another host (default: same origin + nginx /ws/)
# NEXT_PUBLIC_WS_BASE_URL=wss://crm.bozorliii.uz
# PWA / “ilovani o‘rnating” banner (hozircha o‘chiq; keyin: 1)
# NEXT_PUBLIC_CRM_APP_PROMPTS=1
# Yandex Maps (Joylashuv tab) — referrer: http://localhost:3003/*
# Yandex Maps JS API — https://developer.tech.yandex.ru/ (Maps JavaScript API)
# Yandex kabinetida HTTP referrer: crm.bozorliii.online, localhost
NEXT_PUBLIC_MAP_PROVIDER=yandex-maps-api
NEXT_PUBLIC_YANDEX_MAPS_API_KEY=
# Server runtime fallback (ixtiyoriy, odatda yuqoridagi bilan bir xil)
YANDEX_MAPS_API_KEY=
