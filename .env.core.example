# =============================================================================
# CORE server (Server 2) — API + PostgreSQL + Redis + Celery + Bot
# cp .env.core.example .env && nano .env
# docker compose -f docker-compose.core.yml up -d --build
# =============================================================================

APP_NAME=Bozorliii Engine
APP_ENV=production
PRODUCTION=true
APP_DEBUG=false
ALLOW_DEV_MOCKS=false
RUN_SEED=false
API_PREFIX=/api/v1
UVICORN_WORKERS=1

SITE_DOMAIN=bozorliii.online
API_DOMAIN=api.bozorliii.online
CRM_DOMAIN=crm.bozorliii.online
SITE_URL=https://bozorliii.online
MERCHANT_CRM_WEBAPP_URL=https://crm.bozorliii.online

POSTGRES_DB=bozor_ai
POSTGRES_USER=bozor
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
DATABASE_URL=postgresql://bozor:CHANGE_ME_STRONG_DB_PASSWORD@postgres:5432/bozor_ai

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

USER_RATE_LIMIT_PER_MINUTE=10

# Split: brauzerlar WEB nginx orqali keladi — api subdomain ham qo'shing
CORS_ORIGINS=https://bozorliii.online,https://www.bozorliii.online,https://crm.bozorliii.online,https://api.bozorliii.online

JWT_SECRET=CHANGE_ME_USE_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_EXP_MINUTES=10080
ADMIN_API_KEY=CHANGE_ME_ADMIN_KEY

ADMIN_PANEL_ENABLED=true
ADMIN_PANEL_USERNAME=admin
ADMIN_PANEL_PASSWORD=CHANGE_ME_STRONG_PANEL_PASSWORD
ADMIN_PANEL_SECRET=CHANGE_ME_LONG_RANDOM_SECRET

PAYOUT_MODE=batch
PAYOUT_PROVIDER=multicard
MULTICARD_PAYOUT_MOCK=true

TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=

RESEND_API_KEY=
RESEND_FROM_EMAIL=Bozorliii <noreply@bozorliii.online>

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
OPENAI_API_KEY=

ENABLE_ONLINE_CHECKOUT=false
NEXT_PUBLIC_ENABLE_ONLINE_CHECKOUT=false
PREMIUM_CHINA_DEMO_MODE=false
PAYMENT_SANDBOX_MODE=false

BTS_API_BASE_URL=https://api.bts.uz
BTS_API_MOCK=false
TDB_BTS_API_MOCK=false

VISUAL_SEARCH_BACKEND=clip
FASHION_DETECT_BACKEND=yolos

# Media — local volume (CORE da); WEB nginx /api/v1/media proxy qiladi
MEDIA_STORAGE_BACKEND=local

# API port (WEB server VPC dan ulanadi)
CORE_API_PORT=8000

# --- 4GB split performance (kam RAM, tez start) ---
AI_WARMUP_ON_START=false
FASHION_DETECT_BACKEND=heuristic
DB_POOL_SIZE=4
DB_MAX_OVERFLOW=2

# WEB server private IP — firewall skripti uchun
WEB_PRIVATE_IP=10.0.0.1
