## Local production-like env (Docker, no nginx, http://localhost)
APP_ENV=local-prod
APP_DEBUG=false
API_PREFIX=/api/v1
UVICORN_WORKERS=2
RUN_SEED=false

# --- Local URLs (no TLS) ---
SITE_URL=http://localhost:3002
MERCHANT_CRM_WEBAPP_URL=http://localhost:3003
CORS_ORIGINS=http://localhost:3002,http://127.0.0.1:3002,http://localhost:3003,http://127.0.0.1:3003

# --- Database ---
POSTGRES_DB=bozor_ai
POSTGRES_USER=bozor
POSTGRES_PASSWORD=bozor
DATABASE_URL=postgresql://bozor:bozor@postgres:5432/bozor_ai
REDIS_URL=redis://redis:6379/0

# --- JWT / Admin ---
JWT_SECRET=change-me-local-prod
ADMIN_API_KEY=local-prod-admin

# --- Telegram / Email (optional for local) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=
RESEND_API_KEY=
RESEND_FROM_EMAIL=Topdim <noreply@topdim.uz>

# --- AI keys (optional for local if you don't test AI) ---
GROQ_API_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=

# --- Frontend / CRM build-time ---
NEXT_PUBLIC_API_BASE_URL=/api/v1
NEXT_PUBLIC_SITE_URL=http://localhost:3002
NEXT_PUBLIC_MERCHANT_CRM_URL=http://localhost:3003
NEXT_PUBLIC_ENABLE_ONLINE_CHECKOUT=false
NEXT_PUBLIC_YANDEX_MAPS_API_KEY=

# --- Media (local disk by default) ---
MEDIA_STORAGE_BACKEND=local
# For local S3 (MinIO): use docker compose --profile s3dev up -d minio minio-init
# MEDIA_STORAGE_BACKEND=s3
# S3_ENDPOINT_URL=http://minio:9000
# S3_BUCKET=topdim-media
# S3_ACCESS_KEY_ID=minioadmin
# S3_SECRET_ACCESS_KEY=minioadmin
# S3_PUBLIC_BASE_URL=http://localhost:9000/topdim-media
# NEXT_PUBLIC_MEDIA_CDN_URL=http://localhost:9000/topdim-media

FRONTEND_PORT=3002
MERCHANT_CRM_PORT=3003
