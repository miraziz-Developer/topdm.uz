APP_NAME=Bozorliii Engine
APP_ENV=dev
APP_DEBUG=true
API_PREFIX=/api/v1

# =============================================================================
# Database & cache
# =============================================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=bozor_ai
POSTGRES_USER=bozor
POSTGRES_PASSWORD=bozor
DATABASE_URL=postgresql://bozor:bozor@localhost:5432/bozor_ai
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# Auth & admin
# =============================================================================
# Email OTP (Resend) — https://resend.com
RESEND_API_KEY=re_xxxx
RESEND_FROM_EMAIL=Bozorliii <onboarding@resend.dev>

# Telegram OTP (bepul) — foydalanuvchi avval botda /start bosishi kerak
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_BOT_USERNAME=your_bot_username
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=your_bot_username

ADMIN_API_KEY=CHANGE_ME_ADMIN_KEY
# Admin web panel (/admin) — Django-admin uslubidagi panel. Parol bo'sh bo'lsa panel o'chiq.
ADMIN_PANEL_ENABLED=true
ADMIN_PANEL_USERNAME=admin
ADMIN_PANEL_PASSWORD=CHANGE_ME_ADMIN_PANEL_PASSWORD
ADMIN_PANEL_SECRET=CHANGE_ME_LONG_RANDOM_SECRET
# Do'konchilarga to'lov: batch (reestr) yoki auto (payout API)
PAYOUT_MODE=batch
PAYOUT_PROVIDER=multicard
MULTICARD_PAYOUT_MOCK=true
JWT_SECRET=change-me-in-production
# Same-origin proxy (recommended — HttpOnly cookie session)
NEXT_PUBLIC_API_BASE_URL=/api/v1
BACKEND_API_URL=http://127.0.0.1:8000
# WebSocket still connects to FastAPI directly
NEXT_PUBLIC_BACKEND_ORIGIN=http://localhost:8000
NEXT_PUBLIC_SITE_URL=http://localhost:3002

# =============================================================================
# AI & maps
# =============================================================================
GROQ_API_KEY=your-groq-key
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_AGENT_MODEL=
GROQ_VISION_MODEL=llama-3.2-11b-vision-preview
GEMINI_MODEL=gemini-2.0-flash
GOOGLE_API_KEY=your-google-api-key
# Xarita: yandex-maps-api (tavsiya — Yandex Navigator kabi haqiqiy piyoda yo‘l)
NEXT_PUBLIC_MAP_PROVIDER=yandex-maps-api
# Yandex: https://developer.tech.yandex.ru/ → «JavaScript API va HTTP Geocoder» + «Маршрутизация»
# Kalit sozlamalarida «HTTP referrer»: http://localhost:3002/* , http://127.0.0.1:3002/* , https://bozorliii.uz/*
NEXT_PUBLIC_YANDEX_MAPS_API_KEY=your-yandex-maps-key
# Server marshrut (MapLibre zaxirasida ham shu yo‘l chiziladi); bo‘sh qoldirilsa yuqoridagi kalit ishlatiladi
YANDEX_ROUTER_API_KEY=
# MapLibre zaxira (Yandex kalit bo'lmasa)
NEXT_PUBLIC_MAPTILER_KEY=your-maptiler-key
OPENROUTESERVICE_API_KEY=
GRAPHHOPPER_API_KEY=

# Xitoy bozori (hozircha o'chiq — faqat mahalliy bozor)
ENABLE_CHINA_MARKET=false
NEXT_PUBLIC_ENABLE_CHINA_MARKET=false

# Xitoy tovarlari — Taobao DataHub (RapidAPI). https://rapidapi.com — kalitni commit qilmang.
RAPIDAPI_KEY=
PREMIUM_CHINA_CATALOG_IDS=
PREMIUM_CNY_TO_UZS_RATE=1950
PREMIUM_MARGIN_PCT=15
PREMIUM_CARGO_RATE_USD_PER_KG=8
# BTS/uchrashuv: true = demo vitrina (Taobao API shart emas). Production: false
PREMIUM_CHINA_DEMO_MODE=false

FRONTEND_PORT=3002
MERCHANT_CRM_PORT=3003
MERCHANT_CRM_WEBAPP_URL=http://localhost:3003
NEXT_PUBLIC_MERCHANT_CRM_URL=http://localhost:3003

# =============================================================================
# Media & storage
# =============================================================================
MEDIA_STORAGE_BACKEND=local
# Production: s3 — docs/MEDIA_S3_CDN.md
# S3_ENDPOINT_URL=
# S3_BUCKET=bozorliii-media
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_PUBLIC_BASE_URL=https://media.bozorliii.uz
# NEXT_PUBLIC_MEDIA_CDN_URL=https://media.bozorliii.uz
# Dev MinIO: docker compose --profile s3dev up -d minio minio-init
# MEDIA_STORAGE_BACKEND=s3
# S3_ENDPOINT_URL=http://minio:9000
# S3_PUBLIC_BASE_URL=http://localhost:9000/bozorliii-media
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# =============================================================================
# Payments & delivery
# =============================================================================
ENABLE_ONLINE_CHECKOUT=true
NEXT_PUBLIC_ENABLE_ONLINE_CHECKOUT=true
PAYMENT_CHECKOUT_BASE_URL=http://localhost:3002
CLICK_SERVICE_ID=
CLICK_SECRET_KEY=
CLICK_MERCHANT_ID=
# Webhook URL (Click kabineti):
#   POST https://api.bozorliii.online/api/v1/payments/callback/click
#   yoki alohida: /payments/click/prepare va /payments/click/complete
# Production callback IP (vergul bilan).
# PAYMENT_CALLBACK_IP_WHITELIST=185.234.113.1,185.234.113.2
PAYMENT_CALLBACK_MAX_AGE_SECONDS=900
# PAYMENT_SANDBOX_MODE=true

# BTS Express yetkazish (asosiy logistika)
BTS_API_BASE_URL=https://api.bts.uz
# Test: https://apitest.bts.uz:28345
BTS_API_LOGIN=
BTS_API_PASSWORD=
# yoki tayyor token:
BTS_API_TOKEN=
BTS_API_MOCK=true
BTS_DEFAULT_CITY_CODE=0101
BTS_POLL_INTERVAL_SECONDS=1800
# Webhook: POST https://api.bozorliii.online/api/v1/delivery/callback/bts
BTS_WEBHOOK_SECRET=
