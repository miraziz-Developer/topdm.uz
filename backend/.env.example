APP_NAME=Bozor-AI Engine
APP_ENV=dev
APP_DEBUG=true
API_PREFIX=/api/v1

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=bozor_ai
POSTGRES_USER=bozor
POSTGRES_PASSWORD=bozor

REDIS_URL=redis://localhost:6379/0

CORS_ORIGINS=

# REQUIRED — Bozor-AI stylist (official groq SDK + httpx client). Never commit real keys.
GROQ_API_KEY=your_groq_key
# 70B reasoning (legacy llama3-70b-8192 auto-maps to llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_AGENT_MODEL=
GROQ_VISION_MODEL=llama-3.2-11b-vision-preview
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=your_google_api_key
GEMINI_MODEL=gemini-1.5-flash
OPENAI_API_KEY=your_openai_key
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_BOT_USERNAME=your_bot_username
RESEND_API_KEY=re_xxxx
RESEND_FROM_EMAIL=Bozor AI <onboarding@resend.dev>
ENABLE_ONLINE_CHECKOUT=true
CLICK_SERVICE_ID=
CLICK_SECRET_KEY=
CLICK_MERCHANT_ID=
PAYME_MERCHANT_ID=
PAYME_SECRET_KEY=
PAYMENT_CALLBACK_IP_WHITELIST=
YANDEX_DELIVERY_TOKEN=
YANDEX_DELIVERY_BASE_URL=https://b2b.taxi.yandex.net
YANDEX_DELIVERY_RUB_TO_UZS=150

MERCHANT_ALERT_IDLE_DAYS=3
MERCHANT_ALERT_LEAD_HOURS=24
MERCHANT_CRM_WEBAPP_URL=http://localhost:3003

JWT_SECRET=change-me-in-production
