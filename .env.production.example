# Production environment — copy to .env and fill every secret.
# Deploy: docker compose -f docker-compose.prod.yml up -d --build

APP_NAME=Bozorliii Engine
APP_ENV=production
PRODUCTION=true
APP_DEBUG=false
ALLOW_DEV_MOCKS=false
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
API_PREFIX=/api/v1
UVICORN_WORKERS=1
RUN_SEED=false

# --- Domains (Nginx reverse proxy — docker-compose.prod.yml) ---
SITE_DOMAIN=bozorliii.online
API_DOMAIN=api.bozorliii.online
CRM_DOMAIN=crm.bozorliii.online
SITE_URL=https://bozorliii.online
MERCHANT_CRM_WEBAPP_URL=https://crm.bozorliii.online

# --- Database (strong password required) ---
POSTGRES_DB=bozor_ai
POSTGRES_USER=bozor
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
DATABASE_URL=postgresql://bozor:CHANGE_ME_STRONG_DB_PASSWORD@postgres:5432/bozor_ai

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Global API rate limit (requests/min per authenticated user baseline; IP = 3×)
USER_RATE_LIMIT_PER_MINUTE=10

# --- CORS (HTTPS only, comma-separated) ---
CORS_ORIGINS=https://bozorliii.online,https://www.bozorliii.online,https://crm.bozorliii.online

# --- JWT (openssl rand -hex 32) ---
JWT_SECRET=CHANGE_ME_USE_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_EXP_MINUTES=10080

# --- Admin reporting API ---
ADMIN_API_KEY=CHANGE_ME_ADMIN_KEY

# --- Admin web panel (/admin, SQLAdmin) ---
ADMIN_PANEL_ENABLED=true
ADMIN_PANEL_USERNAME=admin
ADMIN_PANEL_PASSWORD=CHANGE_ME_STRONG_PANEL_PASSWORD
ADMIN_PANEL_SECRET=CHANGE_ME_LONG_RANDOM_SECRET

# --- Do'konchilarga to'lov (payout) ---
# batch = reestr fayl + qo'lda tasdiq (self-employed); auto = payout API (YaTT/MChJ + shartnoma)
PAYOUT_MODE=batch
PAYOUT_PROVIDER=multicard
MULTICARD_PAYOUT_BASE_URL=https://mesh.multicard.uz
MULTICARD_PAYOUT_APP_ID=
MULTICARD_PAYOUT_SECRET=
MULTICARD_PAYOUT_MOCK=true

# --- Telegram OTP auth (bepul) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=

# --- Mehmon buyurtma qidiruv SMS (Eskiz.uz) ---
ESKIZ_EMAIL=
ESKIZ_PASSWORD=
# yoki to'g'ridan-to'g'ri token:
ESKIZ_API_TOKEN=
ESKIZ_FROM=4546

# --- Email OTP (Resend) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=Bozorliii <noreply@bozorliii.online>

# --- AI (production: GROQ majburiy; embedding uchun GOOGLE yoki OPENAI) ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-2
# Rasm qidiruv: clip = bepul mahalliy (tavsiya), gemini = Google quota
VISUAL_SEARCH_BACKEND=clip
CLIP_IMAGE_MODEL=Qdrant/Unicom-ViT-B-16
VISUAL_SEARCH_USE_GEMINI=false
# Matn embedding (ixtiyoriy agar GOOGLE_API_KEY bor bo‘lsa)
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
ANTHROPIC_API_KEY=

# --- Frontend / CRM (build-time for Docker images) ---
# Browser must use same-origin proxy (nginx → Next → FastAPI with session cookie).
NEXT_PUBLIC_API_BASE_URL=/api/v1
NEXT_PUBLIC_SITE_URL=https://bozorliii.online
NEXT_PUBLIC_MERCHANT_CRM_URL=https://crm.bozorliii.online
# Optional analytics (production only)
NEXT_PUBLIC_YANDEX_METRIKA_ID=
# Never enable in production unless staging demo content is intentional:
# NEXT_PUBLIC_ALLOW_DEV_MOCKS=false
# --- To'lov ---
# Demo/staging: sandbox (haqiqiy kalitsiz test)
# ENABLE_ONLINE_CHECKOUT=true
# NEXT_PUBLIC_ENABLE_ONLINE_CHECKOUT=true
# PAYMENT_SANDBOX_MODE=true
# ALLOW_PAYMENT_SANDBOX_IN_PRODUCTION=true
ENABLE_ONLINE_CHECKOUT=false
NEXT_PUBLIC_ENABLE_ONLINE_CHECKOUT=false
PREMIUM_CHINA_DEMO_MODE=false
PUBLISH_VISUAL_EMBED_LIGHTWEIGHT=false
NEXT_PUBLIC_DEMO_FAKE_DATA=false
# --- BTS Express yetkazish (asosiy logistika) ---
BTS_API_BASE_URL=https://api.bts.uz
BTS_API_LOGIN=
BTS_API_PASSWORD=
# yoki token:
BTS_API_TOKEN=
BTS_API_MOCK=false
BTS_WEBHOOK_SECRET=
BTS_DEFAULT_CITY_CODE=0101

TDB_BTS_API_MOCK=false
CLICK_SERVICE_ID=
CLICK_SECRET_KEY=
CLICK_MERCHANT_ID=
PAYMENT_CHECKOUT_BASE_URL=https://bozorliii.online
PAYMENT_CALLBACK_IP_WHITELIST=
PAYMENT_CALLBACK_MAX_AGE_SECONDS=600
PAYMENT_SANDBOX_MODE=false
ALLOW_PAYMENT_SANDBOX_IN_PRODUCTION=false
PAYMENT_SANDBOX_CLICK_SERVICE_ID=sandbox-service
PAYMENT_SANDBOX_CLICK_SECRET_KEY=sandbox-click-secret
# Click Business (self-employed) — Merchant API + hosted to'lov sahifasi
CLICK_MERCHANT_USER_ID=
CLICK_API_BASE_URL=https://api.click.uz/v2/merchant
CLICK_PAY_BASE_URL=https://my.click.uz/services/pay
CLICK_HOSTED_CHECKOUT=true
# Q-PAY / PLUM (myuzcard) — self-employed host-to-host (business.plum.uz)
QPAY_BASE_URL=
QPAY_SERVICE_ID=
QPAY_MERCHANT_ID=
QPAY_SECRET_KEY=
QPAY_API_KEY=

# --- Xarita (frontend Docker build) ---
NEXT_PUBLIC_MAP_PROVIDER=yandex-maps-api
NEXT_PUBLIC_YANDEX_MAPS_API_KEY=
YANDEX_ROUTER_API_KEY=
FRONTEND_PORT=3002
MERCHANT_CRM_PORT=3003

# --- Visual search (CLIP local + YOLOs fashion detect) ---
VISUAL_SEARCH_BACKEND=clip
FASHION_DETECT_BACKEND=yolos

# --- Media (production: Cloudflare R2 — docs/MEDIA_S3_CDN.md) ---
# bozor_uploads volume = temp/local fallback; set s3 + creds for CDN URLs.
MEDIA_STORAGE_BACKEND=s3
S3_ENDPOINT_URL=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
S3_BUCKET=bozorliii-media
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=https://media.bozorliii.online
S3_REGION=auto
# Frontend Next/Image — build vaqtida (Docker frontend build args)
NEXT_PUBLIC_MEDIA_CDN_URL=https://media.bozorliii.online

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=products
