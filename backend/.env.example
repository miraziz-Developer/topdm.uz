# Backend-only kalitlar. Umumiy monorepo .env uchun root `.env.example` dan boshlang.
# Docker compose root `.env` faylini ishlatadi.

APP_NAME=Bozorliii Engine
APP_ENV=dev
APP_DEBUG=true
# Production: APP_ENV=production or PRODUCTION=true forces ALLOW_DEV_MOCKS=false
ALLOW_DEV_MOCKS=true
SENTRY_DSN=
GROQ_API_KEY_BACKUP=
API_PREFIX=/api/v1

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=bozor_ai
POSTGRES_USER=bozor
POSTGRES_PASSWORD=bozor

REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Global API rate limit (requests/min per IP, middleware)
USER_RATE_LIMIT_PER_MINUTE=10

CORS_ORIGINS=

# REQUIRED — Bozorliii stylist (official groq SDK + httpx client). Never commit real keys.
GROQ_API_KEY=your_groq_key
# 70B reasoning (legacy llama3-70b-8192 auto-maps to llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_AGENT_MODEL=
GROQ_VISION_MODEL=llama-3.2-11b-vision-preview
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=your_google_api_key
GEMINI_MODEL=gemini-1.5-flash
OPENAI_API_KEY=your_openai_key
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_BOT_USERNAME=your_bot_username
# AI support escalation — CRM da ko'rsatiladi (@sizning_username)
PLATFORM_SUPPORT_TELEGRAM_USERNAME=your_admin_username
RESEND_API_KEY=re_xxxx
RESEND_FROM_EMAIL=Bozorliii <onboarding@resend.dev>
# Mahsulot ustamasi (mijoz narxi = do'kon bazasi + %)
PLATFORM_PRODUCT_MARKUP_PCT=15
MERCHANT_DEBT_BLOCK_THRESHOLD_UZS=100000
SUBSCRIPTIONS_ENABLED=false

ENABLE_ONLINE_CHECKOUT=true
# Click Business — o'zini o'zi band qilgan shaxslar uchun ham (shartnomasiz ro'yxatdan o'tish).
# business.click.uz dan: SERVICE_ID, MERCHANT_ID, MERCHANT_USER_ID, SECRET_KEY olinadi.
CLICK_SERVICE_ID=
CLICK_SECRET_KEY=
CLICK_MERCHANT_ID=
CLICK_MERCHANT_USER_ID=
CLICK_API_BASE_URL=https://api.click.uz/v2/merchant
CLICK_PAY_BASE_URL=https://my.click.uz/services/pay
CLICK_HOSTED_CHECKOUT=true
PAYMENT_CALLBACK_IP_WHITELIST=
PAYMENT_CALLBACK_MAX_AGE_SECONDS=600
# Sandbox (local test): callbacks + signatures are validated with sandbox keys.
PAYMENT_SANDBOX_MODE=false
PAYMENT_SANDBOX_CLICK_SERVICE_ID=sandbox-service
PAYMENT_SANDBOX_CLICK_SECRET_KEY=sandbox-click-secret
# Q-PAY / PLUM (myuzcard) — self-employed host-to-host. business.plum.uz dan olinadi.
QPAY_BASE_URL=
QPAY_SERVICE_ID=
QPAY_MERCHANT_ID=
QPAY_SECRET_KEY=
QPAY_API_KEY=
BTS_API_BASE_URL=https://api.bts.uz
BTS_API_LOGIN=
BTS_API_PASSWORD=
BTS_API_TOKEN=
BTS_API_MOCK=true
BTS_DEFAULT_CITY_CODE=0101

# Premium market — Taobao DataHub (RapidAPI). Never commit real keys.
RAPIDAPI_KEY=
TAOBAO_DATAHUB_HOST=taobao-datahub.p.rapidapi.com
TAOBAO_DATAHUB_BASE_URL=https://taobao-datahub.p.rapidapi.com
PREMIUM_CNY_TO_UZS_RATE=1950
PREMIUM_MARGIN_PCT=15
PREMIUM_MARGIN_MULTIPLIER=1.15
PREMIUM_CARGO_RATE_USD_PER_KG=8
PREMIUM_PRICE_ROUND_UZS=1000
PREMIUM_LOCAL_COURIER_BASE_UZS=25000
# Vergul bilan Taobao item ID (bo'sh = default vitrina IDlari, hammasi API orqali import)
PREMIUM_CHINA_CATALOG_IDS=

MERCHANT_ALERT_IDLE_DAYS=3
MERCHANT_ALERT_LEAD_HOURS=24
MERCHANT_CRM_WEBAPP_URL=http://localhost:3003

JWT_SECRET=change-me-in-production

# Visual search / fashion detect (docker-compose.prod overrides FASHION_DETECT_BACKEND=yolos)
VISUAL_SEARCH_BACKEND=clip
FASHION_DETECT_BACKEND=yolos

# Media — local dev; production: s3 (see docs/MEDIA_S3_CDN.md)
MEDIA_STORAGE_BACKEND=local
S3_ENDPOINT_URL=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=
S3_REGION=auto

# BTS legacy env fallbacks (asosiy BTS_* o'rniga ham qabul qilinadi)
TDB_BTS_API_BASE_URL=https://api.bts.uz
TDB_BTS_API_TOKEN=
TDB_BTS_API_MOCK=true
TDB_BTS_POLL_INTERVAL_SECONDS=2700
