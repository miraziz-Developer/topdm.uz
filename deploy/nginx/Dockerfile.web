# syntax=docker/dockerfile:1
FROM nginx:1.27-alpine

RUN apk add --no-cache curl gettext \
    && rm -f /etc/nginx/conf.d/default.conf \
    && mkdir -p /var/www/certbot /etc/nginx/ssl /etc/nginx/templates

COPY production-web.conf.template /etc/nginx/templates/nginx.conf.template
COPY docker-entrypoint-web.sh /docker-entrypoint-web.sh
RUN chmod +x /docker-entrypoint-web.sh

EXPOSE 80 443

ENTRYPOINT ["/docker-entrypoint-web.sh"]
HEALTHCHECK --interval=30s --timeout=5s --retries=3 \
  CMD curl -fsSk https://127.0.0.1/health -H "Host: bozorliii.online" >/dev/null 2>&1 || exit 1
