APP_NAME=Bozorliii Engine
APP_ENV=dev
APP_DEBUG=true
# Production: APP_ENV=production or PRODUCTION=true forces ALLOW_DEV_MOCKS=false
ALLOW_DEV_MOCKS=true
SENTRY_DSN=
GROQ_API_KEY_BACKUP=
API_PREFIX=/api/v1

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=bozor_ai
POSTGRES_USER=bozor
POSTGRES_PASSWORD=bozor

REDIS_URL=redis://localhost:6379/0

CORS_ORIGINS=

# REQUIRED — Bozorliii stylist (official groq SDK + httpx client). Never commit real keys.
GROQ_API_KEY=your_groq_key
# 70B reasoning (legacy llama3-70b-8192 auto-maps to llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_AGENT_MODEL=
GROQ_VISION_MODEL=llama-3.2-11b-vision-preview
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=your_google_api_key
GEMINI_MODEL=gemini-1.5-flash
OPENAI_API_KEY=your_openai_key
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_BOT_USERNAME=your_bot_username
RESEND_API_KEY=re_xxxx
RESEND_FROM_EMAIL=Bozorliii <onboarding@resend.dev>
# Mahsulot ustamasi (mijoz narxi = do'kon bazasi + %)
PLATFORM_PRODUCT_MARKUP_PCT=15
MERCHANT_DEBT_BLOCK_THRESHOLD_UZS=100000
SUBSCRIPTIONS_ENABLED=false

ENABLE_ONLINE_CHECKOUT=true
CLICK_SERVICE_ID=
CLICK_SECRET_KEY=
CLICK_MERCHANT_ID=
PAYME_MERCHANT_ID=
PAYME_SECRET_KEY=
PAYMENT_CALLBACK_IP_WHITELIST=
PAYMENT_CALLBACK_MAX_AGE_SECONDS=600
# Sandbox (local test): callbacks + signatures are validated with sandbox keys.
PAYMENT_SANDBOX_MODE=false
PAYMENT_SANDBOX_CLICK_SERVICE_ID=sandbox-service
PAYMENT_SANDBOX_CLICK_SECRET_KEY=sandbox-click-secret
PAYMENT_SANDBOX_PAYME_MERCHANT_ID=sandbox-merchant
PAYMENT_SANDBOX_PAYME_SECRET_KEY=sandbox-payme-secret
YANDEX_DELIVERY_TOKEN=
YANDEX_DELIVERY_BASE_URL=https://b2b.taxi.yandex.net
YANDEX_DELIVERY_RUB_TO_UZS=150

# Premium market — Taobao DataHub (RapidAPI). Never commit real keys.
RAPIDAPI_KEY=
TAOBAO_DATAHUB_HOST=taobao-datahub.p.rapidapi.com
TAOBAO_DATAHUB_BASE_URL=https://taobao-datahub.p.rapidapi.com
PREMIUM_CNY_TO_UZS_RATE=1950
PREMIUM_MARGIN_PCT=15
PREMIUM_MARGIN_MULTIPLIER=1.15
PREMIUM_CARGO_RATE_USD_PER_KG=8
PREMIUM_PRICE_ROUND_UZS=1000
PREMIUM_LOCAL_COURIER_BASE_UZS=25000
# Vergul bilan Taobao item ID (bo'sh = default vitrina IDlari, hammasi API orqali import)
PREMIUM_CHINA_CATALOG_IDS=

MERCHANT_ALERT_IDLE_DAYS=3
MERCHANT_ALERT_LEAD_HOURS=24
MERCHANT_CRM_WEBAPP_URL=http://localhost:3003

JWT_SECRET=change-me-in-production

# topdmbozor.uz — Click P2P + SMS-Gate + BTS (tdb_* jadvallar)
TDB_CLICK_P2P_CARD_NUMBER=
# SMS webhook HMAC kaliti (productionda majburiy; devda bo'sh = imzo o'tkaziladi)
TDB_SMS_WEBHOOK_SECRET=
TDB_BTS_API_BASE_URL=https://api.bts.uz
TDB_BTS_API_TOKEN=
TDB_BTS_API_MOCK=true
TDB_BTS_FEE_UZS=25000
TDB_BTS_PAYOUT_CARD_NUMBER=
TDB_PLATFORM_COMMISSION_PCT=10
TDB_BTS_POLL_INTERVAL_SECONDS=2700
TDB_P2P_PROVIDER_URL=https://api.provayder.uz
TDB_P2P_PROVIDER_API_KEY=
TDB_P2P_PROVIDER_MOCK=true
