# =============================================================================
# WEB server (Server 1) — Nginx + Frontend + CRM
# API CORE serverda (VPC private IP).
#
# cp .env.web.example .env && nano .env
# bash deploy/ufw-web.sh
# bash deploy/bootstrap-ssl.sh   # DNS WEB public IP ga qarab
# docker compose -f docker-compose.web.yml up -d --build
# =============================================================================

APP_ENV=production
PRODUCTION=true

# --- SPLIT: CORE server VPC private IP (DigitalOcean → Droplet → Private network) ---
CORE_BACKEND_HOST=10.0.0.2
BACKEND_API_URL=http://10.0.0.2:8000

# Browser WebSocket / to'g'ridan-to'g'ri API (chat)
NEXT_PUBLIC_BACKEND_ORIGIN=https://api.bozorliii.online

SITE_URL=https://bozorliii.online
MERCHANT_CRM_WEBAPP_URL=https://crm.bozorliii.online

NEXT_PUBLIC_API_BASE_URL=/api/v1
NEXT_PUBLIC_SITE_URL=https://bozorliii.online
NEXT_PUBLIC_MERCHANT_CRM_URL=https://crm.bozorliii.online
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=

NEXT_PUBLIC_ENABLE_ONLINE_CHECKOUT=false
NEXT_PUBLIC_MAP_PROVIDER=yandex-maps-api
NEXT_PUBLIC_YANDEX_MAPS_API_KEY=

# Media URL lar (CORE orqali nginx proxy)
NEXT_PUBLIC_MEDIA_CDN_URL=https://media.bozorliii.online

HTTP_PORT=80
HTTPS_PORT=443

# Node heap limit (2× Next.js 4GB serverda)
NODE_OPTIONS=--max-old-space-size=460
NGINX_WORKER_PROCESSES=2
